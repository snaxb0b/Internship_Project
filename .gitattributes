# Normalize text files
* text=auto
# Source code uses LF
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.conf text eol=lf
*.sh text eol=lf
*.svg text eol=lf
# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pt binary
*.onnx binary
*.engine binary
weights/rtdetr-l.pt filter=lfs diff=lfs merge=lfs -text
weights/rtdetr-x.pt filter=lfs diff=lfs merge=lfs -text
